{
  "name": "scip-debugger",
  "displayName": "SCIP Debugger",
  "description": "Debug scip indexes locally",
  "publisher": "matthew-nitschke",
  "version": "0.0.4",
  "repository": "https://github.com/matthewnitschke/vscode-scip-debugger",
  "icon": "images/logo.png",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "scip-debugger.apply",
        "title": "Apply SCIP Index"
      },
      {
        "command": "scip-debugger.refresh",
        "title": "Refresh SCIP Index",
        "icon": "$(refresh)"
      },
      {
        "command": "scip-debugger.showRawData",
        "title": "Show Raw Data"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "scip-debugger",
          "name": "SCIP Debugger",
          "when": "scip-debugger.hasApplied"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "scip-debugger.refresh",
          "when": "view == scip-debugger",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "scip-debugger.showRawData",
          "when": "view == scip-debugger && viewItem == hasSelector"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.104.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
